{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@cybersim/kernel": [
        "./packages/kernel/src"
      ],
      "@cybersim/ui": [
        "./packages/ui/src"
      ],
      "@cybersim/shared": [
        "./packages/shared/src"
      ],
      "@cybersim/proto": [
        "./packages/proto/src"
      ],
      "@cybersim/wasm-crypto": [
        "./packages/wasm-crypto/src"
      ],
      "@cybersim/terminal": [
        "./packages/terminal/src"
      ],
      "@cybersim/netstack": [
        "./packages/netstack/src"
      ],
      "@cybersim/hostos": [
        "./packages/hostos/src"
      ],
      "@cybersim/threatintel": [
        "./packages/threatintel/src"
      ],
      "@cybersim/ai": [
        "./packages/ai/src"
      ],
      "@cybersim/geo": [
        "./packages/geo/src"
      ],
      "@cybersim/sound": [
        "./packages/sound/src"
      ],
      "@cybersim/fs": [
        "./packages/fs/src"
      ],
      "@cybersim/time": [
        "./packages/time/src"
      ],
      "@cybersim/deception": [
        "./packages/deception/src"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    ".turbo",
    "pkg",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
